.overview-strip { display:grid; grid-template-columns:repeat(4,1fr); background:#fff; border:1px solid #dfe2e6; border-radius:6px; margin-bottom:12px; }
.overview-strip > view { padding:10px 4px; text-align:center; border-right:1px solid #eceef0; min-width:0; }
.overview-strip > view:last-child { border-right:0; }
.strip-label { display:block; color:#838b94; font-size:10px; }
.strip-value { display:block; margin-top:3px; color:#1f242a; font-size:13px; font-weight:600; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.vehicle-stage { height:430px; display:flex; align-items:stretch; gap:6px; padding:16px 8px; background:#dfe3e6; border:1px solid #cbd1d6; border-radius:6px; }
.wheel-column { width:72px; flex:none; display:flex; flex-direction:column; justify-content:space-between; }
.wheel { position:relative; height:136px; overflow:hidden; display:flex; flex-direction:column; justify-content:center; align-items:center; border:3px solid #454b52; border-radius:5px; color:#f7f8f9; background:#626a73; }
.power-fill { position:absolute; left:0; right:0; bottom:0; min-height:0; opacity:.8; transition:height .18s linear; }
.wheel.idle .power-fill { background:#77818b; }
.wheel.low .power-fill { background:#168aad; }
.wheel.medium .power-fill { background:#e09f3e; }
.wheel.high .power-fill { background:#d64545; }
.wheel.reverse .power-fill { background:#7656a8; }
.wheel-name, .wheel-pwm, .wheel-encoder { position:relative; z-index:1; }
.wheel-name { font-size:11px; }
.wheel-pwm { margin:7px 0 4px; font-size:22px; font-weight:700; }
.wheel-encoder { font-size:10px; color:#eef0f2; }
.car-body { position:relative; flex:1; min-width:0; border:2px solid #606972; border-radius:6px; background:#f8f9fa; box-shadow:inset 0 0 0 5px #e4e7ea; display:flex; flex-direction:column; align-items:center; justify-content:center; }
.front-mark { position:absolute; top:8px; left:50%; transform:translateX(-50%); width:36px; padding:3px 0; text-align:center; color:#fff; background:#303740; border-radius:3px; font-size:11px; }
.heading-arrow { position:relative; width:28px; height:92px; transform-origin:50% 70%; transition:transform .18s linear; }
.arrow-head { position:absolute; top:0; left:5px; width:0; height:0; border-left:9px solid transparent; border-right:9px solid transparent; border-bottom:17px solid #007f82; }
.arrow-shaft { position:absolute; top:16px; left:12px; width:4px; height:62px; background:#007f82; }
.car-standalone { display:flex; flex-direction:column; align-items:center; }
.car-mode { color:#007f82; font-size:22px; font-weight:700; }
.car-state { color:#59616a; }
.car-mode-wrap { text-align:center; margin-top:10px; }
.car-mode-wrap .car-mode { color:#007f82; font-size:22px; font-weight:700; }
.car-mode-wrap .car-state { margin-top:3px; color:#59616a; }
.sensor-array { position:absolute; bottom:13px; left:4px; right:4px; display:flex; justify-content:center; gap:2px; flex-wrap:wrap; }
.sensor { width:20px; height:25px; line-height:23px; text-align:center; border:1px solid #b5bbc2; background:#fff; color:#858d96; font-size:8px; }
.sensor.center { border-color:#007f82; }
.sensor.active { color:#fff; background:#272b30; border-color:#d99a32; }
.legend { display:flex; justify-content:center; gap:16px; padding:10px 0; color:#68717b; font-size:11px; }
.legend > view { display:flex; align-items:center; }
.dot { display:inline-block; width:8px; height:8px; margin-right:4px; border-radius:50%; }
.dot.low { background:#168aad; }.dot.medium { background:#e09f3e; }.dot.high { background:#d64545; }.dot.reverse { background:#7656a8; }
.detail-band { display:grid; grid-template-columns:1fr 1fr; gap:1px; background:#dfe2e6; border:1px solid #dfe2e6; border-radius:6px; overflow:hidden; }
.detail-band > view { padding:10px 12px; background:#fff; }
.detail-band text { display:block; color:#858d96; font-size:11px; }
.detail-value { display:block !important; margin-top:3px; color:#24292f !important; font-size:15px !important; font-weight:600; }
